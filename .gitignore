registered_faces/
*.npy
.insightface/
yolo_test/runs/

# Face-recognition edge runtime state. Keep the example configuration tracked.
ai_perception/face_recognition/edge_face_system/config/edge_local.yaml
ai_perception/face_recognition/edge_face_system/data/
ai_perception/face_recognition/edge_face_system/logs/
ai_perception/face_recognition/edge_face_system/face_registry.json

# ── 데이터셋 / 캡쳐 / 증거 사진 ─────────────────────────────────────────────
datasets/
captures/
evidence/
snapshots/
*.mp4
*.avi
*.mov

# ── DB ─────────────────────────────────────────────────────────────────────
*.sqlite3
*.sqlite3-journal
*.db
local_settings.py
instance/

# ── 테스트 / 정적분석 / 커버리지 ────────────────────────────────────────────
.pytest_cache/
.cache
.coverage
.coverage.*
coverage.xml
htmlcov/
