#!/usr/bin/env bash
set -eo pipefail
if [ -f /opt/ros/jazzy/setup.bash ]; then
  source /opt/ros/jazzy/setup.bash
fi
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-4}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_DIR"
PYTHON_BIN="${ROBOT_FACE_PYTHON:-$HOME/face-env/bin/python}"
if [ ! -x "$PYTHON_BIN" ]; then
  PYTHON_BIN="python3"
fi
PYTHONPATH="$PROJECT_DIR:/home/gyul:/home/gyul/yolo_test:${PYTHONPATH:-}" \
  "$PYTHON_BIN" -m pc_side.turtlebot_udp_display_node "$@"
