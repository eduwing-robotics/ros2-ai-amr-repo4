#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DROIDCAM_CONNECTOR="$SCRIPT_DIR/droidcam_connector"
ROBOT_UDP_SENDER="$SCRIPT_DIR/robot_udp_camera_sender"
RESOLVE_DEVICE="$SCRIPT_DIR/resolve_droidcam_video_device"
SETUP_KERNEL="/home/gyul/droidcam-env/scripts/setup-kernel.sh"
ADB_BIN="${ADB_BIN:-/home/gyul/droidcam-env/tools/platform-tools/adb}"

ADB_SERIAL="${ADB_SERIAL:-__auto__}"
ADB_PORT="${ADB_PORT:-4747}"
UDP_HOST="${UDP_HOST:-192.168.40.7}"
UDP_PORT="${UDP_PORT:-5005}"
HD_DEVICE="${HD_DEVICE:-/dev/video55}"
BASE_DEVICE="${BASE_DEVICE:-/dev/video54}"
HD_SIZE="${HD_SIZE:-1280x960}"
BASE_SIZE="${BASE_SIZE:-640x480}"
HD_WIDTH="${HD_WIDTH:-1280}"
HD_HEIGHT="${HD_HEIGHT:-960}"
BASE_WIDTH="${BASE_WIDTH:-640}"
BASE_HEIGHT="${BASE_HEIGHT:-480}"
HD_FPS="${HD_FPS:-20}"
BASE_FPS="${BASE_FPS:-20}"
JPEG_QUALITY="${JPEG_QUALITY:-65}"
LOG_DIR="${LOG_DIR:-/home/gyul/robot_face_system/logs}"

CONNECTOR_PID=""
UDP_SENDER_PID=""
SELECTED_MODE=""
SELECTED_DEVICE=""
SELECTED_RESOLUTION=""
CONNECTOR_LOG=""
UDP_LOG="$LOG_DIR/globalcam_udp_sender.log"

mkdir -p "$LOG_DIR"

cleanup() {
  local pid=""
  for pid in "$UDP_SENDER_PID" "$CONNECTOR_PID"; do
    if [[ -n "$pid" ]]; then
      kill "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
    fi
  done
}
trap cleanup EXIT INT TERM

device_card_type() {
  local device="$1"
  v4l2-ctl --device="$device" --all 2>/dev/null | awk -F: '
    $1 ~ /^[[:space:]]*Card type[[:space:]]*$/ {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
      print tolower($2)
      exit
    }
  '
}

device_accessible() {
  local device="$1"
  [[ -e "$device" ]] && v4l2-ctl --device="$device" --all >/dev/null 2>&1
}

is_droidcam_hd_device() {
  local device="$1"
  local card_type=""
  card_type="$(device_card_type "$device")"
  [[ "$card_type" == *droidcam-hd* ]]
}

ensure_hd_device() {
  if [[ -e "$HD_DEVICE" ]]; then
    if is_droidcam_hd_device "$HD_DEVICE"; then
      echo "HD device already present: $HD_DEVICE (DroidCam-HD)"
      return 0
    fi
    if device_accessible "$HD_DEVICE"; then
      echo "HD device already present: $HD_DEVICE"
      return 0
    fi
  fi

  echo "Creating HD loopback device: $HD_DEVICE"
  if sudo modprobe v4l2loopback devices=1 video_nr=55 card_label=DroidCam-HD exclusive_caps=0 max_width=1920 max_height=1080; then
    sleep 1
    if [[ -e "$HD_DEVICE" ]] && device_accessible "$HD_DEVICE"; then
      echo "HD loopback device created: $HD_DEVICE"
      return 0
    fi
  fi

  echo "Failed to create or access HD device: $HD_DEVICE" >&2
  return 1
}

ensure_base_device() {
  if [[ -e "$BASE_DEVICE" ]] && device_accessible "$BASE_DEVICE"; then
    echo "Base device already present: $BASE_DEVICE"
    return 0
  fi

  echo "Base device missing; running setup-kernel.sh ${BASE_WIDTH} ${BASE_HEIGHT}"
  if [[ -x "$SETUP_KERNEL" ]]; then
    sudo "$SETUP_KERNEL" "$BASE_WIDTH" "$BASE_HEIGHT" || true
    sleep 1
  else
    echo "setup-kernel script not found: $SETUP_KERNEL" >&2
  fi

  if [[ -e "$BASE_DEVICE" ]] && device_accessible "$BASE_DEVICE"; then
    echo "Base device ready: $BASE_DEVICE"
    return 0
  fi

  echo "Resolving DroidCam video device automatically"
  BASE_DEVICE="$("$RESOLVE_DEVICE" auto)"
  if [[ -n "$BASE_DEVICE" ]] && device_accessible "$BASE_DEVICE"; then
    echo "Resolved base device: $BASE_DEVICE"
    return 0
  fi

  echo "Failed to resolve a usable base DroidCam device." >&2
  return 1
}

check_adb_ready() {
  echo "Checking ADB device: $ADB_SERIAL"
  if [[ ! -x "$ADB_BIN" ]]; then
    echo "ADB binary not found or not executable: $ADB_BIN" >&2
    exit 1
  fi
  "$ADB_BIN" devices -l
  if ! "$ADB_BIN" devices | grep -q "^${ADB_SERIAL}[[:space:]]\+device"; then
    echo "ADB device is not ready: $ADB_SERIAL" >&2
    exit 1
  fi
}

start_connector() {
  local device="$1"
  local size="$2"
  local log_file="$3"

  "$DROIDCAM_CONNECTOR" \
    --mode usb \
    --adb-serial "$ADB_SERIAL" \
    --adb-port "$ADB_PORT" \
    --video-device "$device" \
    --size "$size" \
    >"$log_file" 2>&1 &
  CONNECTOR_PID=$!
  CONNECTOR_LOG="$log_file"
}

stop_connector() {
  if [[ -n "$CONNECTOR_PID" ]]; then
    kill "$CONNECTOR_PID" 2>/dev/null || true
    wait "$CONNECTOR_PID" 2>/dev/null || true
    CONNECTOR_PID=""
  fi
}

connector_alive() {
  [[ -n "$CONNECTOR_PID" ]] && kill -0 "$CONNECTOR_PID" 2>/dev/null
}

hd_has_target_format() {
  v4l2-ctl --device="$HD_DEVICE" --all 2>/dev/null | grep -qE '1280|960'
}

start_udp_sender() {
  local device="$1"
  local width="$2"
  local height="$3"
  local fps="$4"

  "$ROBOT_UDP_SENDER" \
    --camera "$device" \
    --host "$UDP_HOST" \
    --port "$UDP_PORT" \
    --width "$width" \
    --height "$height" \
    --fps "$fps" \
    --camera-fps "$fps" \
    --jpeg-quality "$JPEG_QUALITY" \
    >"$UDP_LOG" 2>&1 &
  UDP_SENDER_PID=$!
}

print_selected_mode() {
  echo
  echo "GlobalCam UDP sender started."
  echo "  mode: $SELECTED_MODE"
  echo "  camera device: $SELECTED_DEVICE"
  echo "  resolution: $SELECTED_RESOLUTION"
  echo "  UDP target: ${UDP_HOST}:${UDP_PORT}"
  echo "  connector log: $CONNECTOR_LOG"
  echo "  udp sender log: $UDP_LOG"
  echo
}

try_hd_mode() {
  if ! ensure_hd_device; then
    return 1
  fi

  if ! device_accessible "$HD_DEVICE"; then
    echo "HD device is not accessible: $HD_DEVICE" >&2
    v4l2-ctl --list-devices >&2 || true
    return 1
  fi

  echo "Starting HD DroidCam connector on $HD_DEVICE ($HD_SIZE)"
  start_connector "$HD_DEVICE" "$HD_SIZE" "$LOG_DIR/globalcam_droidcam_hd.log"
  sleep 3

  if ! connector_alive; then
    echo "HD DroidCam connector failed:" >&2
    tail -n 40 "$CONNECTOR_LOG" >&2 || true
    stop_connector
    return 1
  fi

  if hd_has_target_format; then
    echo "HD format detected on $HD_DEVICE (${HD_WIDTH}x${HD_HEIGHT})"
  else
    echo "HD connector is running; ${HD_WIDTH}x${HD_HEIGHT} format not confirmed yet."
  fi

  echo "Starting HD UDP sender on $HD_DEVICE"
  start_udp_sender "$HD_DEVICE" "$HD_WIDTH" "$HD_HEIGHT" "$HD_FPS"
  sleep 2

  if ! kill -0 "$UDP_SENDER_PID" 2>/dev/null; then
    echo "HD UDP sender failed:" >&2
    tail -n 40 "$UDP_LOG" >&2 || true
    stop_connector
    return 1
  fi

  SELECTED_MODE="HD"
  SELECTED_DEVICE="$HD_DEVICE"
  SELECTED_RESOLUTION="${HD_WIDTH}x${HD_HEIGHT}"
  return 0
}

try_base_mode() {
  stop_connector

  if ! ensure_base_device; then
    return 1
  fi

  echo "Starting base DroidCam connector on $BASE_DEVICE ($BASE_SIZE)"
  start_connector "$BASE_DEVICE" "$BASE_SIZE" "$LOG_DIR/globalcam_droidcam_base.log"
  sleep 3

  if ! connector_alive; then
    echo "Base DroidCam connector failed:" >&2
    tail -n 40 "$CONNECTOR_LOG" >&2 || true
    stop_connector
    return 1
  fi

  if ! device_accessible "$BASE_DEVICE"; then
    echo "Base device is not accessible: $BASE_DEVICE" >&2
    stop_connector
    return 1
  fi

  echo "Starting base UDP sender on $BASE_DEVICE"
  start_udp_sender "$BASE_DEVICE" "$BASE_WIDTH" "$BASE_HEIGHT" "$BASE_FPS"
  sleep 2

  if ! kill -0 "$UDP_SENDER_PID" 2>/dev/null; then
    echo "Base UDP sender failed:" >&2
    tail -n 40 "$UDP_LOG" >&2 || true
    stop_connector
    return 1
  fi

  SELECTED_MODE="BASE"
  SELECTED_DEVICE="$BASE_DEVICE"
  SELECTED_RESOLUTION="${BASE_WIDTH}x${BASE_HEIGHT}"
  return 0
}

check_adb_ready

if try_hd_mode; then
  :
elif try_base_mode; then
  :
else
  echo "Failed to start GlobalCam UDP sender in HD and BASE modes." >&2
  exit 1
fi

print_selected_mode
wait "$UDP_SENDER_PID"
