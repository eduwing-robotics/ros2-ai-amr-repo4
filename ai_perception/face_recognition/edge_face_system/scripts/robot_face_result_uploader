#!/usr/bin/env bash
set -eo pipefail
if [ -f /opt/ros/jazzy/setup.bash ]; then
  source /opt/ros/jazzy/setup.bash
fi
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_DIR"
PYTHONPATH="$PROJECT_DIR:${PYTHONPATH:-}" "$HOME/face-env/bin/python" -m pc_side.result_uploader_node "$@"
