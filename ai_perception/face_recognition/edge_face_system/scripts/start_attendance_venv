#!/usr/bin/env bash
set -euo pipefail

SERVICE_NAME="robot-face-attendance.service"
DROIDCAM_SETUP="/home/gyul/droidcam-env/scripts/setup-kernel.sh"
DROIDCAM_RESOLVER="/home/gyul/robot_face_system/scripts/resolve_droidcam_video_device"

if ! "$DROIDCAM_RESOLVER" auto >/dev/null 2>&1; then
  if [ ! -x "$DROIDCAM_SETUP" ]; then
    echo "DroidCam 가상 카메라 준비 스크립트를 찾을 수 없습니다: $DROIDCAM_SETUP" >&2
    exit 1
  fi

  echo "DroidCam 가상 카메라 장치가 없어 먼저 준비합니다."
  echo "sudo 암호를 물어보면 입력해 주세요."
  "$DROIDCAM_SETUP" 640 480
fi

systemctl --user reset-failed "$SERVICE_NAME" >/dev/null 2>&1 || true

systemctl --user start "$SERVICE_NAME"

if systemctl --user is-active --quiet "$SERVICE_NAME"; then
  echo "안면인식, RealSense, GlobalCam 및 영상 창을 시작했습니다."
  echo "웹 화면: http://127.0.0.1:8090"
else
  echo "안면인식 서비스 시작에 실패했습니다." >&2
  systemctl --user status "$SERVICE_NAME" --no-pager >&2
  exit 1
fi

