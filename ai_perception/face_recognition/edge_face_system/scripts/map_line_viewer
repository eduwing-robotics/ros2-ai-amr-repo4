#!/usr/bin/env bash
set -eo pipefail
if [ -f /opt/ros/jazzy/setup.bash ]; then
  source /opt/ros/jazzy/setup.bash
fi
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_DIR"
PYTHONPATH="$PROJECT_DIR:${PYTHONPATH:-}" "$HOME/face-env/bin/python" -m pc_side.image_viewer \
  --topic "${MAP_LINE_VIEWER_TOPIC:-/map_line/annotated_image}" \
  --window-name "${MAP_LINE_VIEWER_WINDOW:-Green-Line-Viewer}" \
  --max-width "${MAP_LINE_VIEWER_MAX_WIDTH:-960}" \
  "$@"
