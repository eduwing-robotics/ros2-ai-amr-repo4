#!/usr/bin/env bash
set -eo pipefail
if [ -f /opt/ros/jazzy/setup.bash ]; then
  source /opt/ros/jazzy/setup.bash
fi
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_DIR"
PYTHONPATH="$PROJECT_DIR:${PYTHONPATH:-}" "$HOME/face-env/bin/python" -m pc_side.map_line_detector_node \
  --image-topic "${MAP_LINE_IMAGE_TOPIC:-/globalcam/image_raw/compressed}" \
  --window-name "${MAP_LINE_WINDOW_NAME:-Green-Line-GlobalCam}" \
  --max-width "${MAP_LINE_MAX_WIDTH:-960}" \
  "$@"
