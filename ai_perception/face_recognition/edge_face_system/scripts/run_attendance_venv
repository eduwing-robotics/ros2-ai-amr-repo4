#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH="${CONFIG_PATH:-/home/gyul/robot_face_system/config/edge_local.yaml}"
START_REALSENSE="${START_REALSENSE:-true}"
COLOR_PROFILE="${COLOR_PROFILE:-424x240x15}"
DEPTH_PROFILE="${DEPTH_PROFILE:-480x270x15}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/camera/color/image_raw}"
DEPTH_TOPIC="${DEPTH_TOPIC:-/camera/camera/aligned_depth_to_color/image_raw}"
START_DROIDCAM="${START_DROIDCAM:-true}"
DROIDCAM_MODE="${DROIDCAM_MODE:-usb}"
DROIDCAM_VIDEO_DEVICE="${DROIDCAM_VIDEO_DEVICE:-auto}"
DROIDCAM_WIFI_IP="${DROIDCAM_WIFI_IP:-192.168.0.10}"
DROIDCAM_WIFI_PORT="${DROIDCAM_WIFI_PORT:-4747}"
DROIDCAM_ADB_PORT="${DROIDCAM_ADB_PORT:-4747}"
DROIDCAM_ADB_SERIAL="${DROIDCAM_ADB_SERIAL:-__auto__}"
DROIDCAM_SIZE="${DROIDCAM_SIZE:-640x480}"
GLOBALCAM_WIDTH="${GLOBALCAM_WIDTH:-640}"
GLOBALCAM_HEIGHT="${GLOBALCAM_HEIGHT:-480}"
GLOBALCAM_FPS="${GLOBALCAM_FPS:-10}"
GLOBALCAM_CAMERA_FPS="${GLOBALCAM_CAMERA_FPS:-10}"
GLOBALCAM_JPEG_QUALITY="${GLOBALCAM_JPEG_QUALITY:-75}"
REALSENSE_SERIAL="${REALSENSE_SERIAL:-254622071666}"
REALSENSE_PREFLIGHT_ATTEMPTS="${REALSENSE_PREFLIGHT_ATTEMPTS:-12}"
REALSENSE_PREFLIGHT_INTERVAL="${REALSENSE_PREFLIGHT_INTERVAL:-0.5}"

if [ ! -f /opt/ros/jazzy/setup.bash ]; then
  echo "ROS setup file not found: /opt/ros/jazzy/setup.bash" >&2
  exit 1
fi

if [ ! -x /home/gyul/face-env/bin/python ]; then
  echo "Face virtual environment not found: /home/gyul/face-env" >&2
  exit 1
fi

/home/gyul/robot_face_system/scripts/check_config_local "$CONFIG_PATH"

load_realsense_publisher_settings() {
  local config_values=""
  config_values="$(
    /home/gyul/face-env/bin/python - "$CONFIG_PATH" <<'PY'
import sys
from pathlib import Path
import yaml

def get(config, path, default):
    value = config
    for key in path.split("."):
        if not isinstance(value, dict) or key not in value:
            return default
        value = value[key]
    return value

try:
    config = yaml.safe_load(Path(sys.argv[1]).read_text(encoding="utf-8")) or {}
except (FileNotFoundError, OSError):
    config = {}

def as_bool_string(value, default=True):
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in {"true", "1", "yes", "on"}:
            return "true"
        if normalized in {"false", "0", "no", "off"}:
            return "false"
    return "true" if default else "false"

print(f"CONFIG_SNAPSHOT_OUTPUT={get(config, 'ui.snapshot_path', '/tmp/robot_face_annotated.jpg')}")
print(f"CONFIG_SNAPSHOT_FPS={get(config, 'ui.snapshot_fps', 15)}")
print(f"CONFIG_SNAPSHOT_QUALITY={get(config, 'ui.snapshot_quality', 82)}")
print(f"CONFIG_PUBLISH_TOPICS={as_bool_string(get(config, 'realsense.publish_topics', True))}")
print(f"CONFIG_INPUT_MODE={get(config, 'perception.input_mode', 'ros')}")
print(f"CONFIG_DEVICE_ID={get(config, 'device.id', 'edge-dev-001')}")
print(f"CONFIG_RESULT_TOPIC={get(config, 'ros.state_topic', '/face/recognition_state')}")
print(f"CONFIG_ANNOTATED_TOPIC={get(config, 'ros.annotated_topic', '/face/annotated_image')}")
print(f"CONFIG_DET_SIZE={get(config, 'perception.det_size', 320)}")
print(f"CONFIG_ONNX_THREADS={get(config, 'perception.onnx_threads', 2)}")
print(f"CONFIG_EMIT_INTERVAL={get(config, 'perception.emit_interval', 0.1)}")
print(f"CONFIG_PROCESS_FPS={get(config, 'perception.process_fps', 4.0)}")
print(f"CONFIG_PERSON_DETECTOR={get(config, 'perception.person_detector', 'none')}")
print(f"CONFIG_CROP_WIDTH_RATIO={get(config, 'perception.crop_width_ratio', 1.0)}")
print(f"CONFIG_CROP_HEIGHT_RATIO={get(config, 'perception.crop_height_ratio', 1.0)}")
PY
  )"
  eval "$config_values"

  SNAPSHOT_OUTPUT="${SNAPSHOT_OUTPUT:-${CONFIG_SNAPSHOT_OUTPUT:-/tmp/robot_face_annotated.jpg}}"
  SNAPSHOT_FPS="${SNAPSHOT_FPS:-${CONFIG_SNAPSHOT_FPS:-15}}"
  SNAPSHOT_QUALITY="${SNAPSHOT_QUALITY:-${CONFIG_SNAPSHOT_QUALITY:-82}}"
  PUBLISH_REALSENSE_TOPICS="${PUBLISH_REALSENSE_TOPICS:-${CONFIG_PUBLISH_TOPICS:-true}}"
  PERCEPTION_INPUT_MODE="${PERCEPTION_INPUT_MODE:-${CONFIG_INPUT_MODE:-ros}}"
}

load_realsense_publisher_settings
if [[ "$PERCEPTION_INPUT_MODE" != "ros" && "$PERCEPTION_INPUT_MODE" != "direct_realsense" ]]; then
  echo "Invalid PERCEPTION_INPUT_MODE: $PERCEPTION_INPUT_MODE (expected ros or direct_realsense)" >&2
  exit 1
fi
echo "Using perception input mode: $PERCEPTION_INPUT_MODE"
echo "Using UI snapshot output: $SNAPSHOT_OUTPUT"
echo "Using UI snapshot fps: $SNAPSHOT_FPS"
echo "Using UI snapshot quality: $SNAPSHOT_QUALITY"
if [[ "$PERCEPTION_INPUT_MODE" == "ros" ]]; then
  echo "Using RealSense raw topic publishing: $PUBLISH_REALSENSE_TOPICS"
fi

wait_for_realsense() {
  local attempt=1
  local output=""

  while (( attempt <= REALSENSE_PREFLIGHT_ATTEMPTS )); do
    if output="$(rs-enumerate-devices -s 2>/dev/null)"; then
      if [[ -z "$REALSENSE_SERIAL" ]]; then
        if grep -qi "Intel RealSense" <<<"$output"; then
          echo "Using RealSense (auto-detect, no serial filter)"
          return 0
        fi
      elif grep -q "$REALSENSE_SERIAL" <<<"$output"; then
        echo "Using RealSense serial: $REALSENSE_SERIAL"
        return 0
      fi
    fi
    echo "Waiting for RealSense D435 (attempt ${attempt}/${REALSENSE_PREFLIGHT_ATTEMPTS})..." >&2
    sleep "$REALSENSE_PREFLIGHT_INTERVAL"
    attempt=$((attempt + 1))
  done

  echo "RealSense D435 not detected" >&2
  if [[ -n "$REALSENSE_SERIAL" ]]; then
    echo "Expected serial: $REALSENSE_SERIAL" >&2
  fi
  echo "Check USB3 port/cable, then retry" >&2
  rs-enumerate-devices -s >&2 || true
  return 1
}

if [[ "$START_DROIDCAM" == "true" ]]; then
  DROIDCAM_VIDEO_DEVICE="$(
    /home/gyul/robot_face_system/scripts/resolve_droidcam_video_device "$DROIDCAM_VIDEO_DEVICE"
  )"
  echo "Using DroidCam video device: $DROIDCAM_VIDEO_DEVICE"
fi

set +u
# shellcheck disable=SC1091
source /opt/ros/jazzy/setup.bash
set -u

export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-4}"
export ROBOT_FACE_PYTHON=/home/gyul/face-env/bin/python

REALSENSE_PID=""
DIRECT_PERCEPTION_PID=""
GLOBALCAM_UDP_PID=""
START_PERCEPTION="true"

if [[ "$PERCEPTION_INPUT_MODE" == "direct_realsense" ]]; then
  START_PERCEPTION="false"
  wait_for_realsense
  DIRECT_PERCEPTION_ARGS=(
    --color-profile "$COLOR_PROFILE"
    --depth-profile "$DEPTH_PROFILE"
    --result-topic "${CONFIG_RESULT_TOPIC:-/face/recognition_state}"
    --device-id "${CONFIG_DEVICE_ID:-edge-dev-001}"
    --person-detector "${CONFIG_PERSON_DETECTOR:-none}"
    --det-size "${CONFIG_DET_SIZE:-320}"
    --onnx-threads "${CONFIG_ONNX_THREADS:-2}"
    --emit-interval "${CONFIG_EMIT_INTERVAL:-0.1}"
    --process-fps "${CONFIG_PROCESS_FPS:-4.0}"
    --crop-width-ratio "${CONFIG_CROP_WIDTH_RATIO:-0.75}"
    --crop-height-ratio "${CONFIG_CROP_HEIGHT_RATIO:-1.0}"
    --snapshot-output "$SNAPSHOT_OUTPUT"
    --snapshot-fps "$SNAPSHOT_FPS"
    --snapshot-quality "$SNAPSHOT_QUALITY"
  )
  if [[ -n "$REALSENSE_SERIAL" ]]; then
    DIRECT_PERCEPTION_ARGS+=(--serial "$REALSENSE_SERIAL")
  fi
  /home/gyul/robot_face_system/scripts/robot_face_perception_realsense \
    "${DIRECT_PERCEPTION_ARGS[@]}" &
  DIRECT_PERCEPTION_PID=$!
elif [[ "$START_REALSENSE" == "true" ]]; then
  wait_for_realsense
  REALSENSE_ARGS=(
    --color-profile "$COLOR_PROFILE"
    --depth-profile "$DEPTH_PROFILE"
    --image-topic "$IMAGE_TOPIC"
    --depth-topic "$DEPTH_TOPIC"
  )
  if [[ -n "$REALSENSE_SERIAL" ]]; then
    REALSENSE_ARGS+=(--serial "$REALSENSE_SERIAL")
  fi
  REALSENSE_ARGS+=(
    --snapshot-output "$SNAPSHOT_OUTPUT"
    --snapshot-fps "$SNAPSHOT_FPS"
    --snapshot-quality "$SNAPSHOT_QUALITY"
    --publish-image-topics "$PUBLISH_REALSENSE_TOPICS"
  )
  /home/gyul/robot_face_system/scripts/robot_realsense_publisher \
    "${REALSENSE_ARGS[@]}" &
  REALSENSE_PID=$!
else
  DEPTH_TOPIC="none"
fi

cleanup() {
  if [[ -n "$GLOBALCAM_UDP_PID" ]]; then
    kill "$GLOBALCAM_UDP_PID" 2>/dev/null || true
    wait "$GLOBALCAM_UDP_PID" 2>/dev/null || true
  fi
  if [[ -n "$DIRECT_PERCEPTION_PID" ]]; then
    kill "$DIRECT_PERCEPTION_PID" 2>/dev/null || true
    wait "$DIRECT_PERCEPTION_PID" 2>/dev/null || true
  fi
  if [[ -n "$REALSENSE_PID" ]]; then
    kill "$REALSENSE_PID" 2>/dev/null || true
    wait "$REALSENSE_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

/home/gyul/robot_face_system/scripts/start_globalcam_udp_sender &
GLOBALCAM_UDP_PID=$!

ros2 launch /home/gyul/robot_face_system/launch/attendance_local.launch.py \
  config:="$CONFIG_PATH" \
  start_realsense:=false \
  start_snapshot_node:=false \
  start_globalcam:=false \
  start_droidcam:=false \
  droidcam_mode:="$DROIDCAM_MODE" \
  droidcam_video_device:="$DROIDCAM_VIDEO_DEVICE" \
  droidcam_wifi_ip:="$DROIDCAM_WIFI_IP" \
  droidcam_wifi_port:="$DROIDCAM_WIFI_PORT" \
  droidcam_adb_port:="$DROIDCAM_ADB_PORT" \
  droidcam_adb_serial:="$DROIDCAM_ADB_SERIAL" \
  droidcam_size:="$DROIDCAM_SIZE" \
  globalcam_camera:="$DROIDCAM_VIDEO_DEVICE" \
  globalcam_topic:="${GLOBALCAM_TOPIC:-/globalcam/image_raw/compressed}" \
  globalcam_width:="$GLOBALCAM_WIDTH" \
  globalcam_height:="$GLOBALCAM_HEIGHT" \
  globalcam_fps:="$GLOBALCAM_FPS" \
  globalcam_camera_fps:="$GLOBALCAM_CAMERA_FPS" \
  globalcam_jpeg_quality:="$GLOBALCAM_JPEG_QUALITY" \
  image_topic:="$IMAGE_TOPIC" \
  depth_topic:="$DEPTH_TOPIC" \
  start_perception:="$START_PERCEPTION" \
  perception_input_mode:="$PERCEPTION_INPUT_MODE" \
  show_globalcam_viewer:=false \
  show_face_viewer:=false \
  start_cctv_sender:=false
